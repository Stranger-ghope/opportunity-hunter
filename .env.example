# ─────────────────────────────────────────────
# INFERENCE BACKEND (Nosana / local Ollama)
# ─────────────────────────────────────────────
INFERENCE_PROVIDER=nosana          # nosana | ollama | openai
NOSANA_API_URL=https://inference.nosana.io/v1
NOSANA_API_KEY=your_nosana_key_here
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=your_openai_key_here  # fallback only
MODEL_NAME=Qwen/Qwen3.5-27B-Instruct-AWQ   # Nosana-hosted competition endpoint (Qwen3.5-27B-AWQ-4bit)

# ─────────────────────────────────────────────
# REDDIT API
# ─────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=OpportunityHunterBot/1.0

# ─────────────────────────────────────────────
# EMAIL (IMAP for Gmail / other)
# ─────────────────────────────────────────────
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TLS=true
EMAIL_INBOX=INBOX
EMAIL_FILTER_SENDER=alerts@example.com

# ─────────────────────────────────────────────
# PIPELINE
# ─────────────────────────────────────────────
PIPELINE_INTERVAL_MINUTES=30
SCORE_THRESHOLD=60
AUTO_APPLY_THRESHOLD=85
DATA_DIR=./data
LOG_LEVEL=info

# ─────────────────────────────────────────────
# DASHBOARD
# ─────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_SECRET=change_me_in_production
